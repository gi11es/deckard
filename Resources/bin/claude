#!/usr/bin/env bash
# Deckard claude wrapper - injects hooks and session tracking

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Pass through if not in a Deckard terminal or hooks are disabled.
if [[ -z "$DECKARD_SURFACE_ID" || "$DECKARD_HOOKS_DISABLED" == "1" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

unset CLAUDECODE

SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Build hook commands. Each hook sends JSON to the Deckard control socket.
# We write a small helper script that the hooks invoke, to avoid JSON-in-JSON escaping issues.
HOOK_HELPER=$(mktemp /tmp/deckard-hook-XXXXXX.sh)
cat > "$HOOK_HELPER" << 'HOOKEOF'
#!/bin/bash
EVENT="$1"
SURFACE="$DECKARD_SURFACE_ID"
SOCKET="$DECKARD_SOCKET_PATH"
if [[ -n "$SOCKET" ]] && [[ -S "$SOCKET" ]]; then
    printf '{"command":"hook.%s","surfaceId":"%s"}\n' "$EVENT" "$SURFACE" | nc -U "$SOCKET" -w 1 2>/dev/null
fi
HOOKEOF
chmod +x "$HOOK_HELPER"

# Build hooks JSON using the helper script
HOOKS_JSON="{\"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER session-start\",\"timeout\":10}]}],\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER stop\",\"timeout\":10}]}],\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER notification\",\"timeout\":10}]}],\"UserPromptSubmit\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER user-prompt-submit\",\"timeout\":10}]}]}}"

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="${DECKARD_CLAUDE_SESSION_ID:-$(uuidgen | tr '[:upper:]' '[:lower:]')}"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
